{
	"expo": {
		"name": "Kayak Freestyle App",
		"slug": "freestyleapp",
		"platforms": ["android", "ios"],
		"version": "1.2.20",
		"orientation": "portrait",
		"newArchEnabled": true,
		"icon": "./assets/images/icon.png",
		"splash": {
			"image": "./assets/images/splash.png",
			"resizeMode": "contain",
			"backgroundColor": "#ffffff"
		},
		"updates": {
			"fallbackToCacheTimeout": 0
		},
		"android": {
			"package": "com.kayakfreestyle.kayakfreestyleapp",
			"permissions": []
		},
		"assetBundlePatterns": ["**/*"],
		"ios": {
			"buildNumber": "1.2.18",
			"bundleIdentifier": "com.kayakfreestyle.kayakfreestyleapp",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},
		"plugins": [
			[
				"expo-font",
				{
					"fonts": ["./assets/fonts/SpaceMono-Regular.ttf"]
				}
			]
		],
		"extra": {
			"eas": {
				"projectId": "8de4e141-3d11-46b7-a394-c163b149a4e3"
			}
		}
	}
}
